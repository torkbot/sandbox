{
  "name": "@torkbot/sandbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run build:native && tsgo --project tsconfig.build.json --pretty",
    "build:init": "node ./scripts/build-init.ts",
    "build:libkrun-init": "node ./scripts/build-libkrun-init.ts",
    "build:kernel": "node ./scripts/build-kernel.ts",
    "build:rootfs": "node ./scripts/build-rootfs.ts",
    "build:native": "napi build --platform --release --manifest-path crates/sandbox-node/Cargo.toml && node ./scripts/sign-native.ts",
    "check:rust": "cargo check --workspace",
    "test:e2e": "node ./tests/e2e/run.ts",
    "test:rust": "cargo test --workspace",
    "test:unit": "node --test tests/unit/*.test.ts",
    "typecheck": "tsgo --noEmit --pretty"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "@types/node": "^24.12.0",
    "@typescript/native-preview": "7.0.0-dev.20260423.1",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "bson": "^7.2.0"
  }
}
